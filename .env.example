# Copy to `.env` and fill in real values. Never commit the populated file.

# --- Database (required) ---
# Password for the Supernote MariaDB `supernote` user.
SUPERNOTE_DB_PASSWORD=change-me

# --- Database (optional; defaults shown) ---
# Hostname of the MariaDB container on the shared Docker network.
SUPERNOTE_DB_HOST=supernote-mariadb
SUPERNOTE_DB_PORT=3306
SUPERNOTE_DB_USER=supernote
SUPERNOTE_DB_NAME=supernotedb
SUPERNOTE_DB_CONNECT_TIMEOUT=10
SUPERNOTE_DB_POOL_SIZE=5

# --- User scoping (required only for multi-user databases) ---
# Email of the single Supernote user to expose (looked up in the u_user table).
# Auto-detected when the database has exactly one user; required when it has
# more than one (the service otherwise fails fast at startup).
# SUPERNOTE_USER_EMAIL=you@example.com

# --- Authentication (required) ---
# Comma-separated list of API keys. Generate strong random values, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Callers send one as `Authorization: Bearer <key>` or `X-API-Key: <key>`.
API_KEYS=replace-with-a-long-random-key

# --- Rate limiting (optional; defaults shown) ---
# Authenticated callers are NOT rate limited. Only unauthenticated/invalid-key
# requests are throttled per client IP, aggressively, within this window.
RATE_LIMIT_WINDOW_SECONDS=60
UNAUTH_RATE_LIMIT_REQUESTS=10

# --- Operational (optional; defaults shown) ---
LOG_LEVEL=INFO
# Expose interactive Swagger docs at /docs and /openapi.json. Keep false in prod.
ENABLE_DOCS=false
# Reject request bodies larger than this many bytes.
MAX_REQUEST_BODY_BYTES=65536
# Trust X-Forwarded-* headers. Enable ONLY when behind a trusted reverse proxy.
TRUST_PROXY_HEADERS=true
